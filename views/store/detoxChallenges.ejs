<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detox Challenges - Digital Addiction Awareness</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-50 font-sans text-slate-800">

    <!-- Include Navigation Header -->
    <%- include('../partial/head.ejs') %>

    <!-- Main Container -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-10 py-8 sm:py-12">
        
        <!-- Back to Home Link -->
        <a href="/" class="text-blue-600 hover:text-blue-800 mb-4 inline-flex items-center gap-2">
            <i class="fas fa-arrow-left"></i>
            Back to Home
        </a>
        
        <!-- Page Header -->
        <div class="mb-8 sm:mb-12">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div>
                    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-blue-950 mb-2">
                        Detox Challenges
                    </h1>
                    <p class="text-slate-500">Join challenges to improve your digital habits and compete with friends</p>
                </div>
            </div>
        </div>

        <!-- Challenge Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
            <!-- Challenges Completed -->
            <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-semibold text-slate-700">Challenges Completed</h3>
                    <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-green-600">
                        <i class="fas fa-trophy text-lg"></i>
                    </div>
                </div>
                <p class="text-3xl sm:text-4xl font-bold text-green-950 mb-2">7</p>
                <p class="text-sm text-slate-500">Keep up the momentum!</p>
            </div>

            <!-- Active Challenges -->
            <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-semibold text-slate-700">Active Challenges</h3>
                    <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600">
                        <i class="fas fa-fire text-lg"></i>
                    </div>
                </div>
                <p class="text-3xl sm:text-4xl font-bold text-blue-950 mb-2">3</p>
                <p class="text-sm text-slate-500">In progress now</p>
            </div>

            <!-- Current Streak -->
            <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-semibold text-slate-700">Current Streak</h3>
                    <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center text-orange-600">
                        <i class="fas fa-flame text-lg"></i>
                    </div>
                </div>
                <p class="text-3xl sm:text-4xl font-bold text-orange-950 mb-2">12</p>
                <p class="text-sm text-slate-500">Days without limits exceeded</p>
            </div>

            <!-- Total Points -->
            <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-semibold text-slate-700">Total Points</h3>
                    <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-purple-600">
                        <i class="fas fa-star text-lg"></i>
                    </div>
                </div>
                <p class="text-3xl sm:text-4xl font-bold text-purple-950 mb-2">2,450</p>
                <p class="text-sm text-slate-500">Redeem for rewards</p>
            </div>
        </div>

        <!-- Active Challenges Section -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-blue-950 mb-6">Your Active Challenges</h2>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8">
                <!-- Challenge 1 -->
                <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50 hover:shadow-md transition">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center text-white text-2xl flex-shrink-0">
                                <i class="fas fa-bed"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg text-slate-900">Phone-Free Sleep</h3>
                                <p class="text-sm text-slate-500">No phones 1 hour before bed</p>
                            </div>
                        </div>
                        <i class="fas fa-star text-2xl text-amber-400"></i>
                    </div>
                    <p class="text-slate-600 text-sm mb-4">Put your phone away and rest peacefully. This challenge helps improve sleep quality and reduces blue light exposure.</p>
                    
                    <!-- Progress -->
                    <div class="mb-4">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-semibold text-slate-700">Progress: 9 of 14 days</span>
                            <span class="text-sm text-blue-600 font-semibold">64%</span>
                        </div>
                        <div class="w-full bg-slate-200 rounded-full h-2">
                            <div class="bg-gradient-to-r from-blue-500 to-blue-600 h-2 rounded-full progress-bar" data-width="64"></div>
                        </div>
                    </div>

                    <!-- Rewards -->
                    <div class="bg-blue-50 p-3 rounded-lg mb-4">
                        <p class="text-xs text-blue-600 font-semibold">REWARD: 100 Points + Sleep Well Badge</p>
                    </div>

                    <button class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
                        Mark Today Complete
                    </button>
                </div>

                <!-- Challenge 2 -->
                <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-green-50 hover:shadow-md transition">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 bg-gradient-to-br from-green-500 to-green-600 rounded-2xl flex items-center justify-center text-white text-2xl flex-shrink-0">
                                <i class="fas fa-tree"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg text-slate-900">Digital Sunrise</h3>
                                <p class="text-sm text-slate-500">No phone for 1 hour after waking</p>
                            </div>
                        </div>
                        <i class="fas fa-star text-2xl text-amber-400"></i>
                    </div>
                    <p class="text-slate-600 text-sm mb-4">Start your day right! No screens for the first hour after waking helps boost productivity and mental clarity.</p>
                    
                    <!-- Progress -->
                    <div class="mb-4">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-semibold text-slate-700">Progress: 8 of 14 days</span>
                            <span class="text-sm text-green-600 font-semibold">57%</span>
                        </div>
                        <div class="w-full bg-slate-200 rounded-full h-2">
                            <div class="bg-gradient-to-r from-green-500 to-green-600 h-2 rounded-full progress-bar" data-width="57"></div>
                        </div>
                    </div>

                    <!-- Rewards -->
                    <div class="bg-green-50 p-3 rounded-lg mb-4">
                        <p class="text-xs text-green-600 font-semibold">REWARD: 100 Points + Morning Star Badge</p>
                    </div>

                    <button class="w-full px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition font-medium">
                        Mark Today Complete
                    </button>
                </div>

                <!-- Challenge 3 -->
                <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-purple-50 hover:shadow-md transition">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center text-white text-2xl flex-shrink-0">
                                <i class="fas fa-dumbbell"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg text-slate-900">Active Hour</h3>
                                <p class="text-sm text-slate-500">1 hour of physical activity daily</p>
                            </div>
                        </div>
                        <i class="fas fa-star text-2xl text-amber-400"></i>
                    </div>
                    <p class="text-slate-600 text-sm mb-4">Replace screen time with physical activity. Exercise improves mood, health, and reduces dependency on digital devices.</p>
                    
                    <!-- Progress -->
                    <div class="mb-4">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-semibold text-slate-700">Progress: 11 of 14 days</span>
                            <span class="text-sm text-purple-600 font-semibold">79%</span>
                        </div>
                        <div class="w-full bg-slate-200 rounded-full h-2">
                            <div class="bg-gradient-to-r from-purple-500 to-purple-600 h-2 rounded-full progress-bar" data-width="79"></div>
                        </div>
                    </div>

                    <!-- Rewards -->
                    <div class="bg-purple-50 p-3 rounded-lg mb-4">
                        <p class="text-xs text-purple-600 font-semibold">REWARD: 150 Points + Fitness Champion Badge</p>
                    </div>

                    <button class="w-full px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition font-medium">
                        Mark Today Complete
                    </button>
                </div>

                <!-- Challenge 4 - Joined Recently -->
                <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-red-50 hover:shadow-md transition">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 bg-gradient-to-br from-red-500 to-red-600 rounded-2xl flex items-center justify-center text-white text-2xl flex-shrink-0">
                                <i class="fas fa-book"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg text-slate-900">Reading Quest</h3>
                                <p class="text-sm text-slate-500">Read for 30 mins instead of scrolling</p>
                            </div>
                        </div>
                        <i class="fas fa-star text-2xl text-amber-400"></i>
                    </div>
                    <p class="text-slate-600 text-sm mb-4">Swap social media time for reading. Books are a great way to reduce screen time and boost knowledge.</p>
                    
                    <!-- Progress -->
                    <div class="mb-4">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-semibold text-slate-700">Progress: 2 of 14 days</span>
                            <span class="text-sm text-red-600 font-semibold">14%</span>
                        </div>
                        <div class="w-full bg-slate-200 rounded-full h-2">
                            <div class="bg-gradient-to-r from-red-500 to-red-600 h-2 rounded-full progress-bar" data-width="14"></div>
                        </div>
                    </div>

                    <!-- Rewards -->
                    <div class="bg-red-50 p-3 rounded-lg mb-4">
                        <p class="text-xs text-red-600 font-semibold">REWARD: 100 Points + Bookworm Badge</p>
                    </div>

                    <button class="w-full px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition font-medium">
                        Mark Today Complete
                    </button>
                </div>
            </div>
        </div>

        <!-- Available Challenges to Join -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-blue-950 mb-6">Discover More Challenges</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
                <% const availableChallenges = [
                    { title: 'Mindful Monday', desc: 'Start your week with intention. No social media first thing Monday morning.', icon: 'fa-head-side-virus', color: 'bg-indigo-500', difficulty: 'Easy' },
                    { title: 'Social Media Fast', desc: 'Stay off social media for 24 hours. Replace with meaningful conversations.', icon: 'fa-ban', color: 'bg-orange-500', difficulty: 'Hard' },
                    { title: 'Family Time', desc: 'Spend 1 hour with family with zero phone interruptions daily.', icon: 'fa-heart', color: 'bg-pink-500', difficulty: 'Medium' },
                    { title: 'Notification Detox', desc: 'Disable all non-essential notifications for a week.', icon: 'fa-bell-slash', color: 'bg-cyan-500', difficulty: 'Easy' },
                    { title: 'Tech-Free Weekend', desc: 'No digital devices all weekend. Enjoy nature and hobbies.', icon: 'fa-sun', color: 'bg-yellow-500', difficulty: 'Hard' },
                    { title: 'Mindfulness Series', desc: 'Practice 10 mins meditation daily instead of scrolling.', icon: 'fa-om', color: 'bg-teal-500', difficulty: 'Easy' }
                ] %>
                <% availableChallenges.forEach(ch => { %>
                    <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50 hover:shadow-md transition flex flex-col">
                        <div class="flex items-start justify-between mb-4">
                            <div class="<%= ch.color %> w-12 h-12 rounded-xl flex items-center justify-center text-white text-2xl">
                                <i class="fas <%= ch.icon %>"></i>
                            </div>
                            <span class="text-xs font-bold px-2 py-1 bg-slate-100 text-slate-700 rounded-full"><%= ch.difficulty %></span>
                        </div>
                        <h3 class="font-bold text-lg text-slate-900 mb-2"><%= ch.title %></h3>
                        <p class="text-slate-600 text-sm mb-6 flex-1"><%= ch.desc %></p>
                        <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
                            Join Challenge
                        </button>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Leaderboard Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 mb-12">
            <!-- Friends Leaderboard -->
            <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                <h2 class="text-2xl font-bold text-blue-950 mb-6">Friends Leaderboard</h2>
                <div class="space-y-3">
                    <% const friends = [
                        { rank: 1, name: 'Sarah Johnson', points: 3200, badge: 'Gold' },
                        { rank: 2, name: 'Mike Chen', points: 2850, badge: 'Silver' },
                        { rank: 3, name: 'You', points: 2450, badge: 'Bronze', isYou: true },
                        { rank: 4, name: 'Emily Davis', points: 2100, badge: 'Active' },
                        { rank: 5, name: 'Alex Rodriguez', points: 1950, badge: 'Active' }
                    ] %>
                    <% friends.forEach(friend => { %>
                        <div class="flex items-center gap-3 p-4 <%= friend.isYou ? 'bg-blue-50 border border-blue-200' : 'hover:bg-slate-50' %> rounded-lg transition">
                            <div class="text-xl font-bold text-slate-400 w-8"><%= friend.rank %></div>
                            <div class="w-10 h-10 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full flex items-center justify-center text-white font-bold text-sm">
                                <%= friend.name.charAt(0) %>
                            </div>
                            <div class="flex-1">
                                <p class="font-semibold text-slate-900"><%= friend.name %></p>
                                <p class="text-xs text-slate-500"><%= friend.badge %></p>
                            </div>
                            <p class="font-bold text-blue-600"><%= friend.points %> pts</p>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Badges & Achievements -->
            <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                <h2 class="text-2xl font-bold text-blue-950 mb-6">Your Badges</h2>
                <div class="grid grid-cols-2 gap-4">
                    <% const badges = [
                        { name: 'Digital Warrior', icon: 'fa-shield', color: 'text-blue-600', bg: 'bg-blue-100', unlocked: true },
                        { name: 'Sleep Champion', icon: 'fa-bed', color: 'text-purple-600', bg: 'bg-purple-100', unlocked: true },
                        { name: 'Morning Star', icon: 'fa-sun', color: 'text-orange-600', bg: 'bg-orange-100', unlocked: true },
                        { name: 'Fitness Pro', icon: 'fa-dumbbell', color: 'text-green-600', bg: 'bg-green-100', unlocked: true },
                        { name: 'Bookworm', icon: 'fa-book', color: 'text-red-600', bg: 'bg-red-100', unlocked: false },
                        { name: 'Social Fast', icon: 'fa-ban', color: 'text-slate-600', bg: 'bg-slate-100', unlocked: false }
                    ] %>
                    <% badges.forEach(badge => { %>
                        <div class="flex flex-col items-center gap-2 p-4 rounded-lg <%= badge.unlocked ? badge.bg : 'bg-slate-100' %> opacity-<%= badge.unlocked ? '100' : '60' %>">
                            <div class="text-3xl <%= badge.color %>">
                                <i class="fas <%= badge.icon %>"></i>
                            </div>
                            <p class="text-xs font-semibold text-center text-slate-800"><%= badge.name %></p>
                            <% if (!badge.unlocked) { %>
                                <p class="text-xs text-slate-500">Locked</p>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Completed Challenges -->
        <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
            <h2 class="text-2xl font-bold text-blue-950 mb-6">Previously Completed</h2>
            <div class="space-y-3">
                <% const completed = [
                    { title: 'Screen Time Reduction', points: 150, date: 'Feb 15', icon: 'fa-check-circle' },
                    { title: 'App Limit Challenge', points: 100, date: 'Feb 10', icon: 'fa-check-circle' },
                    { title: '7-Day No Scrolling', points: 200, date: 'Feb 01', icon: 'fa-check-circle' },
                    { title: 'Productivity Focus', points: 120, date: 'Jan 28', icon: 'fa-check-circle' }
                ] %>
                <% completed.forEach(c => { %>
                    <div class="flex items-center justify-between p-4 border-b border-slate-100 last:border-0 hover:bg-slate-50 transition">
                        <div class="flex items-center gap-4">
                            <i class="fas <%= c.icon %> text-2xl text-green-600"></i>
                            <div>
                                <p class="font-semibold text-slate-800"><%= c.title %></p>
                                <p class="text-sm text-slate-500">Completed on <%= c.date %></p>
                            </div>
                        </div>
                        <span class="font-bold text-lg text-green-600">+<%= c.points %> pts</span>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="mt-12 sm:mt-16 py-8 sm:py-12 px-4 sm:px-6 md:px-10 bg-blue-950 text-white">
        <div class="max-w-7xl mx-auto text-center">
            <p class="text-blue-100">&copy; 2026 Digital Addiction Awareness. Your journey to digital wellness starts here.</p>
            <div class="mt-4 flex gap-6 justify-center">
                <a href="#" class="hover:text-blue-300 transition text-sm">Privacy Policy</a>
                <a href="#" class="hover:text-blue-300 transition text-sm">Terms of Service</a>
                <a href="#" class="hover:text-blue-300 transition text-sm">Contact Us</a>
            </div>
        </div>
    </footer>

    <script>
        // Apply dynamic widths to progress bars
        document.querySelectorAll('.progress-bar').forEach(el => {
            const width = el.getAttribute('data-width');
            el.style.width = width + '%';
        });
    </script>

</body>
</html>
