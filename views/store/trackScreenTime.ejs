<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Screen Time - Digital Addiction Awareness</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-50 font-sans text-slate-800">

    <!-- Include Navigation Header -->
    <%- include('../partial/head.ejs') %>

    <!-- Main Container -->
    <main class="py-8 sm:py-12 px-4 sm:px-6 md:px-10">
        <div class="max-w-7xl mx-auto">
            <!-- Header -->
            <div class="mb-8 sm:mb-12">
                <a href="/" class="text-blue-600 hover:text-blue-800 mb-4 inline-flex items-center gap-2">
                    <i class="fas fa-arrow-left"></i>
                    Back to Home
                </a>
                <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-blue-950 mb-3">
                    Track Your Screen Time
                </h1>
                <p class="text-slate-600 text-base sm:text-lg">Monitor your digital habits and take control of your screen time</p>
            </div>

            <!-- Today's Overview -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-blue-50 hover:shadow-lg transition">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-sm mb-2">Today's Screen Time</p>
                            <p class="text-3xl font-bold text-blue-900">4h 32m</p>
                        </div>
                        <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center text-blue-600 text-2xl">
                            <i class="fas fa-clock"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-green-50 hover:shadow-lg transition">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-sm mb-2">Daily Goal</p>
                            <p class="text-3xl font-bold text-green-900">5h 0m</p>
                        </div>
                        <div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center text-green-600 text-2xl">
                            <i class="fas fa-bullseye"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-orange-50 hover:shadow-lg transition">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-sm mb-2">Most Used App</p>
                            <p class="text-3xl font-bold text-orange-900">2h 15m</p>
                        </div>
                        <div class="bg-orange-100 w-16 h-16 rounded-full flex items-center justify-center text-orange-600 text-2xl">
                            <i class="fas fa-mobile-alt"></i>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-purple-50 hover:shadow-lg transition">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-sm mb-2">Focus Time</p>
                            <p class="text-3xl font-bold text-purple-900">1h 45m</p>
                        </div>
                        <div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center text-purple-600 text-2xl">
                            <i class="fas fa-brain"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts Section -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
                <!-- App Usage Breakdown -->
                <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                    <h2 class="text-xl sm:text-2xl font-bold text-blue-950 mb-6">App Usage Breakdown</h2>
                    <div class="flex justify-center">
                        <canvas id="appChart" width="300" height="300"></canvas>
                    </div>
                    <div class="mt-6 space-y-3">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <div class="w-3 h-3 bg-blue-600 rounded-full"></div>
                                <span class="text-slate-600">Social Media</span>
                            </div>
                            <span class="font-semibold text-slate-800">2h 15m (49%)</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <div class="w-3 h-3 bg-indigo-600 rounded-full"></div>
                                <span class="text-slate-600">Entertainment</span>
                            </div>
                            <span class="font-semibold text-slate-800">1h 30m (33%)</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <div class="w-3 h-3 bg-purple-600 rounded-full"></div>
                                <span class="text-slate-600">Productivity</span>
                            </div>
                            <span class="font-semibold text-slate-800">47m (17%)</span>
                        </div>
                    </div>
                </div>

                <!-- Weekly Comparison -->
                <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                    <h2 class="text-xl sm:text-2xl font-bold text-blue-950 mb-6">Weekly Comparison</h2>
                    <canvas id="weeklyChart"></canvas>
                    <p class="text-slate-600 text-sm text-center mt-4">You're using <span class="font-semibold text-blue-600">15% less</span> screen time this week!</p>
                </div>
            </div>

            <!-- Hourly Activity & Goals Section -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
                <!-- Hourly Activity -->
                <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                    <h2 class="text-xl sm:text-2xl font-bold text-blue-950 mb-6">Hourly Activity</h2>
                    <canvas id="hourlyChart"></canvas>
                </div>

                <!-- Goals & Targets -->
                <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50">
                    <h2 class="text-xl sm:text-2xl font-bold text-blue-950 mb-6">Your Goals</h2>
                    <div class="space-y-4">
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <span class="font-semibold text-slate-700">Daily Screen Time Limit</span>
                                <span class="text-blue-600 font-bold">4/5 hours</span>
                            </div>
                            <div class="w-full bg-blue-100 rounded-full h-3">
                                <div class="bg-blue-600 h-3 rounded-full" style="width: 80%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <span class="font-semibold text-slate-700">Social Media Reduction</span>
                                <span class="text-orange-600 font-bold">115/180 min</span>
                            </div>
                            <div class="w-full bg-orange-100 rounded-full h-3">
                                <div class="bg-orange-600 h-3 rounded-full" style="width: 64%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <span class="font-semibold text-slate-700">Focus Time Target</span>
                                <span class="text-green-600 font-bold">105/120 min</span>
                            </div>
                            <div class="w-full bg-green-100 rounded-full h-3">
                                <div class="bg-green-600 h-3 rounded-full" style="width: 88%"></div>
                            </div>
                        </div>
                    </div>
                    <button class="w-full mt-6 bg-blue-600 hover:bg-blue-700 text-white px-4 py-3 rounded-lg font-semibold transition transform hover:scale-105">
                        <i class="fas fa-plus"></i> Set New Goal
                    </button>
                </div>
            </div>

            <!-- Top Apps -->
            <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-blue-50 mb-8">
                <h2 class="text-xl sm:text-2xl font-bold text-blue-950 mb-6">Your Top Apps</h2>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-slate-200">
                                <th class="text-left py-3 px-4 text-slate-600 font-semibold">App Name</th>
                                <th class="text-left py-3 px-4 text-slate-600 font-semibold">Time Today</th>
                                <th class="text-left py-3 px-4 text-slate-600 font-semibold">Weekly Avg</th>
                                <th class="text-left py-3 px-4 text-slate-600 font-semibold">Trend</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b border-slate-100 hover:bg-blue-50 transition">
                                <td class="py-4 px-4 flex items-center gap-3">
                                    <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 text-lg">
                                        <i class="fab fa-instagram"></i>
                                    </div>
                                    <span class="font-semibold text-slate-800">Instagram</span>
                                </td>
                                <td class="py-4 px-4 text-slate-700">1h 15m</td>
                                <td class="py-4 px-4 text-slate-700">2h 30m</td>
                                <td class="py-4 px-4">
                                    <span class="inline-flex items-center gap-1 text-green-600 font-semibold">
                                        <i class="fas fa-arrow-down"></i> 50%
                                    </span>
                                </td>
                            </tr>
                            <tr class="border-b border-slate-100 hover:bg-blue-50 transition">
                                <td class="py-4 px-4 flex items-center gap-3">
                                    <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center text-red-600 text-lg">
                                        <i class="fab fa-youtube"></i>
                                    </div>
                                    <span class="font-semibold text-slate-800">YouTube</span>
                                </td>
                                <td class="py-4 px-4 text-slate-700">1h 0m</td>
                                <td class="py-4 px-4 text-slate-700">1h 45m</td>
                                <td class="py-4 px-4">
                                    <span class="inline-flex items-center gap-1 text-green-600 font-semibold">
                                        <i class="fas fa-arrow-down"></i> 43%
                                    </span>
                                </td>
                            </tr>
                            <tr class="border-b border-slate-100 hover:bg-blue-50 transition">
                                <td class="py-4 px-4 flex items-center gap-3">
                                    <div class="w-10 h-10 bg-sky-100 rounded-lg flex items-center justify-center text-sky-600 text-lg">
                                        <i class="fab fa-twitter"></i>
                                    </div>
                                    <span class="font-semibold text-slate-800">Twitter</span>
                                </td>
                                <td class="py-4 px-4 text-slate-700">45m</td>
                                <td class="py-4 px-4 text-slate-700">1h 20m</td>
                                <td class="py-4 px-4">
                                    <span class="inline-flex items-center gap-1 text-red-600 font-semibold">
                                        <i class="fas fa-arrow-up"></i> 15%
                                    </span>
                                </td>
                            </tr>
                            <tr class="hover:bg-blue-50 transition">
                                <td class="py-4 px-4 flex items-center gap-3">
                                    <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center text-green-600 text-lg">
                                        <i class="fas fa-envelope"></i>
                                    </div>
                                    <span class="font-semibold text-slate-800">Email</span>
                                </td>
                                <td class="py-4 px-4 text-slate-700">32m</td>
                                <td class="py-4 px-4 text-slate-700">55m</td>
                                <td class="py-4 px-4">
                                    <span class="inline-flex items-center gap-1 text-green-600 font-semibold">
                                        <i class="fas fa-arrow-down"></i> 42%
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Recommendations -->
            <div class="bg-gradient-to-r from-blue-500 to-indigo-600 text-white p-6 sm:p-8 rounded-2xl shadow-lg mb-8">
                <h2 class="text-xl sm:text-2xl font-bold mb-4">Personalized Recommendations</h2>
                <div class="space-y-3">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-lightbulb text-yellow-300 text-lg mt-1"></i>
                        <div>
                            <p class="font-semibold mb-1">Reduce Social Media Time</p>
                            <p class="text-blue-100 text-sm">Consider limiting Instagram to 30 minutes per day. Your current usage is 49% of total screen time.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="fas fa-lightbulb text-yellow-300 text-lg mt-1"></i>
                        <div>
                            <p class="font-semibold mb-1">Keep up the good work!</p>
                            <p class="text-blue-100 text-sm">Your focus time is excellent! You're spending nearly 40% of your screen time on productive activities.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="fas fa-lightbulb text-yellow-300 text-lg mt-1"></i>
                        <div>
                            <p class="font-semibold mb-1">Enable App Limits</p>
                            <p class="text-blue-100 text-sm">Set up automatic app limits for entertainment apps to help maintain your daily goal of 5 hours.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
                <button class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition transform hover:scale-105 flex items-center justify-center gap-2">
                    <i class="fas fa-bell"></i> Enable Notifications
                </button>
                <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg font-semibold transition transform hover:scale-105 flex items-center justify-center gap-2">
                    <i class="fas fa-download"></i> Download Report
                </button>
                <button class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-lg font-semibold transition transform hover:scale-105 flex items-center justify-center gap-2">
                    <i class="fas fa-share-alt"></i> Share Progress
                </button>
            </div>
        </div>
    </main>

    <!-- Include Footer -->
    <%- include('../partial/footer.ejs') %>

    <script>
        // App Usage Breakdown - Pie Chart
        const appCtx = document.getElementById('appChart').getContext('2d');
        new Chart(appCtx, {
            type: 'doughnut',
            data: {
                labels: ['Social Media', 'Entertainment', 'Productivity'],
                datasets: [{
                    data: [49, 33, 18],
                    backgroundColor: ['#2563eb', '#4f46e5', '#7c3aed'],
                    borderColor: '#ffffff',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });

        // Weekly Comparison - Bar Chart
        const weeklyCtx = document.getElementById('weeklyChart').getContext('2d');
        new Chart(weeklyCtx, {
            type: 'bar',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Screen Time (hours)',
                    data: [6.5, 5.8, 6.2, 4.5, 5.0, 5.2, 4.3],
                    backgroundColor: '#2563eb',
                    borderColor: '#1e40af',
                    borderWidth: 1,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 8,
                        ticks: {
                            callback: function(value) {
                                return value + 'h';
                            }
                        }
                    }
                }
            }
        });

        // Hourly Activity - Line Chart
        const hourlyCtx = document.getElementById('hourlyChart').getContext('2d');
        new Chart(hourlyCtx, {
            type: 'line',
            data: {
                labels: ['6 AM', '9 AM', '12 PM', '3 PM', '6 PM', '9 PM', '12 AM'],
                datasets: [{
                    label: 'Activity (minutes)',
                    data: [15, 45, 120, 85, 110, 95, 30],
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37, 99, 235, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#2563eb',
                    pointBorderColor: '#ffffff',
                    pointBorderWidth: 2,
                    pointRadius: 5
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value + 'm';
                            }
                        }
                    }
                }
            }
        });
    </script>
</body>
</html>
